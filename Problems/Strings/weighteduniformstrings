/*
Problem Statement: Weighted Uniform Strings

You are given a string s consisting of lowercase English letters and a list of integer queries.

A uniform substring is a substring made up of only one repeated character. For example:

"a"
"bb"
"ccc"

are uniform substrings, while:

"ab"
"bca"
"cdc"

are not.

Each lowercase letter has a weight equal to its position in the English alphabet:

Character	Weight
a	1
b	2
c	3
...	...
z	26

The weight of a uniform substring is the sum of the weights of all its characters.

For example:

Weight of "a" = 1
Weight of "cc" = 3 + 3 = 6
Weight of "ddd" = 4 + 4 + 4 = 12

For each query, determine whether there exists at least one uniform substring in s whose weight is exactly equal to the query value.

Return:

"Yes" if such a uniform substring exists.
"No" otherwise.
Example

Input

s = "abccddde"

queries = [1, 3, 12, 5, 9, 10]

Uniform Substrings and Their Weights

Substring	Weight
a	1
b	2
c	3
cc	6
d	4
dd	8
ddd	12
e	5

Possible weights are:

{1, 2, 3, 4, 5, 6, 8, 12}

Checking the queries:

Query	Answer
1	Yes
3	Yes
12	Yes
5	Yes
9	No
10	No

Output

Yes
Yes
Yes
Yes
No
No

Constraints
1 ≤ |s| ≤ 10^5
1 ≤ queries.size() ≤ 10^5
1 ≤ query ≤ 10^7

The goal is to answer all queries efficiently without generating every possible substring.
*/

#include <bits/stdc++.h>
using namespace std;

vector<string> weightedUniformStrings(string s, vector<int> queries) {
    unordered_set<int> weights;

    int current=0;
    char previ='\0';
    for(char ch : s) {

        int val = ch-'a'+1;
        if(ch==previ){
            current+=val;
        }
        else
            current= val;
        weights.insert(current);

        previ=ch;
    }
    vector<string> ans;

    for(int q : queries) {
        if(weights.count(q)){
            ans.push_back("Yes");
        }
        else
            ans.push_back("No");
    }
    return ans;
}

int main() {
    string s;
    cin >> s;

    int n;
    cin >> n;

    vector<int> queries(n);

    for (int i = 0; i < n; i++) {
        cin >> queries[i];
    }

    vector<string> result = weightedUniformStrings(s, queries);

    for (string x : result) {
        cout << x << endl;
    }

    return 0;
}
